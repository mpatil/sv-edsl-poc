## File generated by the BNF Converter (bnfc 2.9.7).

SVLEX = ${LEXPATH}/lex
SVLEX_OPTS = -v

SVACC = ${YACCPATH}/svacc
SVACC_OPTS = -SVsemantic=svtype -v

QRUN = qrun
QRUN_OPTS = -64 -sv -mfcu -permissive -l comp.log -suppress 2875,2240 +incdir+./ +UVM_NO_RELNOTES
VCS = vcs
VCS_OPTS = -full64 -sverilog -l comp.log
VCS_SIM = lib_interp_C_0
TOPLEVEL = test
FUSESOC_RUN_DIR = lib_interp_C_0
TEST_VCS_DIR = ${FUSESOC_RUN_DIR}/test-vcs
SIM_SCRIPT = lib_interp_C_0.scr
TEST_INPUT = ../../test.w

.PHONY : all run qrun vcs clean distclean fusesoc

all : run

clean :
	rm -rf C/CParser.svh C/CLexer.svh qrun.out simv simv.daidir csrc ucli.key test-vcs ${FUSESOC_RUN_DIR}

distclean : clean
	rm -f C/CAbsyn.svh C/CAbsyn.sv C.l C.y C/CPrinter.sv C/CPrinter.svh C/CInterpBase.sv C/CInterpBase.svh Test.sv C/C_pkg.sv C/C.core comp.log vcs.log modelsim.ini C/*.bak y.output Makefile C.tex

C/CLexer.svh : C.l
	${SVLEX} ${SVLEX_OPTS} C.l
	mv lex.yy.v C/CLexer.svh

C/CParser.svh : C.y
	${SVACC} ${SVACC_OPTS} C.y
	mv Parser.svh C/CParser.svh
	cp ${YACCPATH}/bio.svh C

.PHONY: fusesoc
fusesoc : C/CParser.svh C/CLexer.svh
	fusesoc --cores-root C run --no-export --target=test --build-root=. --setup lib:interp:C

run : fusesoc Test.sv
	@if command -v ${QRUN} >/dev/null 2>&1; then \
	  ${MAKE} qrun; \
	elif command -v ${VCS} >/dev/null 2>&1; then \
	  ${MAKE} vcs; \
	else \
	  echo "Neither ${QRUN} nor ${VCS} found on PATH"; \
	  exit 127; \
	fi

.PHONY: qrun
qrun : fusesoc Test.sv
	cd ${TEST_VCS_DIR} && ${QRUN} ${QRUN_OPTS} +define+DEFINE_ENTRYPOINTS -F ${SIM_SCRIPT} ../../../Test.sv +input=${TEST_INPUT}

.PHONY: vcs
vcs : fusesoc Test.sv
	cd ${TEST_VCS_DIR} && ${VCS} ${VCS_OPTS} +define+DEFINE_ENTRYPOINTS +incdir+../.. -f ${SIM_SCRIPT} -top ${TOPLEVEL} -o ${VCS_SIM}
	cd ${TEST_VCS_DIR} && ./${VCS_SIM} -l vcs.log +input=${TEST_INPUT}
